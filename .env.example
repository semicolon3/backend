# ====================================================================
# .env 템플릿 파일 (Git에 커밋됨, 실제 값은 적지 마세요)
#
# 사용법:
#   1. 이 파일을 ".env"로 복사
#   2. 각 값을 실제 본인 키/비밀번호로 채우기
#   3. 앱 재시작
# ====================================================================

# --- Database (Aiven MySQL) ---
DB_PASSWORD=

# --- JWT 토큰 서명 키 (256bit 이상의 랜덤 문자열 권장) ---
# 생성 예시: openssl rand -base64 32  또는 https://generate-secret.now.sh/32
JWT_SECRET=

# --- 국가법령정보센터 OPEN API ---
# https://open.law.go.kr 가입 후 발급. 값은 등록 이메일의 @ 앞부분.
LAW_API_KEY=

# --- OpenAI API ---
# https://platform.openai.com/api-keys 에서 발급. sk-proj-... 형태.
OPENAI_API_KEY=
